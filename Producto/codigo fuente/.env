# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI Configuration (for RAG system)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Flow Payment Gateway (for production)
VITE_FLOW_API_KEY=your-flow-api-key-here
VITE_FLOW_SECRET_KEY=your-flow-secret-here
VITE_FLOW_BASE_URL=https://www.flow.cl/api

# Resend Email Service (for production emails)
# Get your API key from: https://resend.com
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=SotLoy Conecta <noreply@sotloy.cl>
RESEND_FROM_NAME=SotLoy Conecta

# =====================================================
# SERVER-SIDE ENVIRONMENT VARIABLES (for Edge Functions)
# These should be configured in Supabase Dashboard
# =====================================================

# Supabase Service Role Key (for Edge Functions only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI API Key (for LOY RAG system)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Note: Store these in Supabase Dashboard > Project Settings > Edge Functions