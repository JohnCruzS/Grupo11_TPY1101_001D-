# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI/GitHub Models Configuration (for LOY RAG)
# Set one provider in Supabase Edge Functions secrets:
# LOY_LLM_PROVIDER=github|openai|groq
# GITHUB_MODELS_API_KEY=your-github-models-token-here
# GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
# GITHUB_MODELS_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama3-8b-8192
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Flow Payment Gateway
# NOTA: las variables VITE_FLOW_* NO son usadas por el código de pago actual.
# Los pagos van exclusivamente a través de Edge Functions (payments-initiate /
# payments-confirm). Configura las vars sin prefijo VITE_ en Supabase Dashboard.
# Las variables de abajo son solo referencia documental.
VITE_FLOW_API_KEY=your-flow-api-key-here
VITE_FLOW_SECRET_KEY=your-flow-secret-here
VITE_FLOW_BASE_URL=https://www.flow.cl/api

# Resend Email Service (for production emails)
# Get your API key from: https://resend.com
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=SotLoy Conecta <noreply@sotloy.cl>
RESEND_FROM_NAME=SotLoy Conecta

# =====================================================
# SERVER-SIDE ENVIRONMENT VARIABLES (for Edge Functions)
# These should be configured in Supabase Dashboard
# =====================================================

# Supabase Service Role Key (for Edge Functions only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== FLOW CHILE — EDGE FUNCTIONS (configurar en Supabase Dashboard > Secrets) =====
# La URL de Flow es automática: sandbox por defecto, producción solo si se
# configura FLOW_API_URL=https://www.flow.cl/api explícitamente.
#
# OBLIGATORIOS para que funcione el pago:
FLOW_API_KEY=your-flow-api-key
FLOW_SECRET_KEY=your-flow-secret-key

# OPCIONAL — solo para cambiar a producción (sin esto = sandbox automático):
# FLOW_API_URL=https://www.flow.cl/api

# URL pública del frontend — Flow redirige aquí post-pago
# Sin esto, Flow redirige a http://localhost:5173 (válido solo en local)
PUBLIC_SITE_URL=https://sotloy.cl

# LOY RAG provider (OpenAI-compatible)
LOY_LLM_PROVIDER=github

# GitHub Models API Key (recommended if you want GitHub-hosted AI)
# Get from: https://github.com/marketplace?type=models
GITHUB_MODELS_API_KEY=your-github-models-token-here
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
GITHUB_MODELS_MODEL=gpt-4o-mini

# OpenAI fallback
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Groq fallback
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192

# URL pública del frontend (OBLIGATORIO para que los emails de recuperación apunten a producción)
# Configurar en Supabase Dashboard > Edge Functions > Secrets
SITE_URL=https://sotloy.cl

# Note: Store these in Supabase Dashboard > Project Settings > Edge Functions